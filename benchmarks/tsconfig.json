{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "..",
    "paths": {
      "@asafelobotomy/ceeline-schema": ["../packages/schema/src/index.ts"],
      "@asafelobotomy/ceeline-core": ["../packages/core/src/index.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
