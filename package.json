{
  "name": "ceeline",
  "version": "0.1.0",
  "private": true,
  "description": "Schema-first standalone transport layer for compact internal AI communication.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asafelobotomy/ceeline.git"
  },
  "homepage": "https://github.com/asafelobotomy/ceeline#readme",
  "bugs": "https://github.com/asafelobotomy/ceeline/issues",
  "workspaces": [
    "packages/*",
    "adapters/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "benchmark": "tsx benchmarks/run.ts",
    "typecheck": "tsc -b --pretty false",
    "clean": "tsc -b --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "publish:all": "npm run build && npm publish --workspace=packages/schema --workspace=packages/core --workspace=packages/cli --workspace=adapters/mcp-server --access public --tag latest"
  },
  "devDependencies": {
    "@jtml/core": "^0.1.2",
    "@msgpack/msgpack": "^3.1.3",
    "@sriinnu/pakt": "^0.7.0",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^4.1.4",
    "cbor-x": "^1.6.4",
    "js-tiktoken": "^1.0.21",
    "jsonschema-key-compression": "^1.7.0",
    "tonl-mcp-bridge": "^1.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3",
    "zipson": "^0.2.12"
  }
}
