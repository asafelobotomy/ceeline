{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ceeline.dev/schema/memory-payload-1.0.schema.json",
  "title": "Ceeline Memory Payload v1",
  "type": "object",
  "required": [
    "summary",
    "facts",
    "ask",
    "artifacts",
    "metadata",
    "memory_kind",
    "durability",
    "citations"
  ],
  "properties": {
    "summary": { "type": "string" },
    "facts": { "type": "array", "items": { "type": "string" } },
    "ask": { "type": "string" },
    "artifacts": { "type": "array", "items": true },
    "metadata": { "type": "object", "additionalProperties": true },
    "memory_kind": {
      "enum": ["fact", "decision", "research"]
    },
    "durability": {
      "enum": ["session", "project", "persistent"]
    },
    "citations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}