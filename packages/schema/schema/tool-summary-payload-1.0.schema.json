{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ceeline.dev/schema/tool-summary-payload-1.0.schema.json",
  "title": "Ceeline Tool Summary Payload v1",
  "type": "object",
  "required": [
    "summary",
    "facts",
    "ask",
    "artifacts",
    "metadata",
    "tool_name",
    "outcome",
    "elapsed_ms"
  ],
  "properties": {
    "summary": { "type": "string" },
    "facts": { "type": "array", "items": { "type": "string" } },
    "ask": { "type": "string" },
    "artifacts": { "type": "array", "items": true },
    "metadata": { "type": "object", "additionalProperties": true },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "enum": ["success", "failure", "partial", "skipped"]
    },
    "elapsed_ms": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
