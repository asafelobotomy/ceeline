{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ceeline.dev/schema/digest-payload-1.0.schema.json",
  "title": "Ceeline Digest Payload v1",
  "type": "object",
  "required": [
    "summary",
    "facts",
    "ask",
    "artifacts",
    "metadata",
    "window",
    "status",
    "metrics"
  ],
  "properties": {
    "summary": { "type": "string" },
    "facts": { "type": "array", "items": { "type": "string" } },
    "ask": { "type": "string" },
    "artifacts": { "type": "array", "items": true },
    "metadata": { "type": "object", "additionalProperties": true },
    "window": {
      "enum": ["turn", "session", "run"]
    },
    "status": {
      "enum": ["ok", "warn", "error"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    }
  },
  "additionalProperties": true
}