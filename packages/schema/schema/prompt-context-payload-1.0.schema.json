{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ceeline.dev/schema/prompt-context-payload-1.0.schema.json",
  "title": "Ceeline Prompt Context Payload v1",
  "type": "object",
  "required": [
    "summary",
    "facts",
    "ask",
    "artifacts",
    "metadata",
    "phase",
    "priority",
    "source_ref"
  ],
  "properties": {
    "summary": { "type": "string" },
    "facts": { "type": "array", "items": { "type": "string" } },
    "ask": { "type": "string" },
    "artifacts": { "type": "array", "items": true },
    "metadata": { "type": "object", "additionalProperties": true },
    "phase": {
      "enum": ["system", "injection", "retrieval", "grounding"]
    },
    "priority": {
      "type": "number"
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
