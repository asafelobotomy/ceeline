{
  "name": "@asafelobotomy/ceeline-schema",
  "version": "0.2.0",
  "description": "TypeScript types, enums, code maps, and JSON schemas for the Ceeline compact transport",
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist/",
    "schema/",
    "dict/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asafelobotomy/ceeline.git",
    "directory": "packages/schema"
  },
  "homepage": "https://github.com/asafelobotomy/ceeline#readme",
  "bugs": "https://github.com/asafelobotomy/ceeline/issues",
  "keywords": ["ceeline", "ai", "compact", "transport", "token-efficient", "schema", "json-schema", "llm", "agent"],
  "engines": { "node": ">=18.0.0" },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./envelope-1.0.schema.json": "./dist/schema/envelope-1.0.schema.json",
    "./handoff-payload-1.0.schema.json": "./dist/schema/handoff-payload-1.0.schema.json",
    "./digest-payload-1.0.schema.json": "./dist/schema/digest-payload-1.0.schema.json",
    "./memory-payload-1.0.schema.json": "./dist/schema/memory-payload-1.0.schema.json",
    "./dict/ceeline.aff": "./dict/ceeline.aff",
    "./dict/ceeline.dic": "./dict/ceeline.dic"
  }
}